{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-apcu": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-openssl": "*",
        "ext-pdo_pgsql": "*",
        "doctrine/dbal": "^3.10.5",
        "doctrine/doctrine-bundle": "^2.18.2",
        "doctrine/doctrine-migrations-bundle": "^3.7.0",
        "doctrine/orm": "^3.6.3",
        "dragonmantank/cron-expression": "^3.6",
        "egulias/email-validator": "^4.0.4",
        "hyvor/internal": "^4.0.11",
        "mlocati/spf-lib": "^3.3",
        "phpdocumentor/reflection-docblock": "^5.6.7",
        "phpmailer/phpmailer": "^6.12",
        "phpstan/phpdoc-parser": "^2.3.2",
        "promphp/prometheus_client_php": "^2.15.0",
        "runtime/frankenphp-symfony": "^0.2.0",
        "symfony/console": "7.4.*",
        "symfony/doctrine-messenger": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10.0",
        "symfony/framework-bundle": "7.4.*",
        "symfony/lock": "7.4.*",
        "symfony/messenger": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/process": "7.4.*",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/rate-limiter": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/scheduler": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*",
            "docker": false
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "phpstan/phpstan": "^2.1.46",
        "phpunit/phpunit": "^12.5.19",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/maker-bundle": "^1.67.0",
        "zenstruck/foundry": "^2.9.2",
        "zenstruck/messenger-test": "^1.14.0"
    }
}
